# =============================================================================
# 批量图片编辑工作台 — 环境变量模板
# 复制为 .env.local 后填入真实值，.env.local 不会被提交到 git。
# =============================================================================

# ── 脚本生成（Gemini / OpenAI 兼容） ──────────────────────────────────────
# GEMINI_API_KEY 是必填项；其余三个为可选项。
GEMINI_BASE_URL=https://geekai.co/api
GEMINI_API_KEY=sk-your-gemini-api-key-here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_STYLE=openai-compatible

# ── 图片生成供应商（种子数据 fallback，实际在 UI 中配置） ───────────────
# 以下变量仅在数据库中没有对应供应商记录时作为初始值写入。
GEEKAI_BASE_URL=https://geekai.co/api
GEEKAI_API_KEY=sk-your-geekai-api-key-here

PACKY_BASE_URL=https://www.packyapi.com
PACKY_API_KEY=sk-your-packy-api-key-here

COMPANY_BASE_URL=https://company-gateway.example.com
COMPANY_API_KEY=sk-your-company-api-key-here

# ── 视频生成供应商（种子数据 fallback） ──────────────────────────────────
# 可灵视频
KLING_VIDEO_BASE_URL=https://api.kling.example.com
KLING_VIDEO_API_KEY=sk-your-kling-api-key-here
KLING_VIDEO_MODEL=kling-v1

# 即梦视频
JIMENG_VIDEO_BASE_URL=https://api.jimeng.example.com
JIMENG_VIDEO_API_KEY=sk-your-jimeng-api-key-here
JIMENG_VIDEO_MODEL=jimeng-v1
